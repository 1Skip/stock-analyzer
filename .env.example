# 本机私密配置模板
# 使用方法：复制本文件为 .env，然后把下面的占位值改成你自己的配置。
# .env 已在 .gitignore 中，不会提交到 GitHub。

# ===== LLM 总开关：个股分析页 AI 辅助解读 =====
# 用到位置：个股分析页面 -> AI 辅助解读。
# 作用：把已有技术指标快照翻译成自然语言解释，不参与核心选股和评分。
AI_ENABLED=true
AI_API_KEY=替换成你的模型API_KEY
AI_BASE_URL=https://api.deepseek.com
AI_MODEL=deepseek-chat
AI_TEMPERATURE=0.2
AI_MAX_TOKENS=1024
AI_CACHE_TTL=300

# ===== LLM 补充协作模式：个股分析页三 Agent 解释 =====
# 用到位置：个股分析页面 -> AI 辅助解读 -> 启用补充协作模式。
# 作用：技术分析、风险评估、综合决策三段式解释；仍不参与核心选股。
AI_MULTI_AGENT=false

# ===== LLM 多空辩论：日报中的外部 LLM 辩论 =====
# 用到位置：每日完整报告、自选股日报。
# 作用：对自选股生成多头、空头、风控经理三方观点；未配置 Key 时自动跳过。
AI_DEBATE_ENABLED=false
AI_DEBATE_MAX_SYMBOLS=3

# ===== 本机定时任务（可选）=====
# 本机可按时间生成日报和 T+1 计划缓存，不配置在线推送渠道。
SCHEDULE_ENABLED=true
SCHEDULE_TIME=15:30
SCHEDULE_RUN_IMMEDIATELY=false

# ===== 每日完整报告（可选）=====
DAILY_REPORT_ENABLED=true
DAILY_REPORT_INCLUDE_RECOMMENDATIONS=false
DAILY_REPORT_DIR=reports/history

# ===== T+1 推荐计划自动预生成（可选）=====
# 只提前运行既有推荐策略，不改变选股条件。
T1_PLAN_AUTO_ENABLED=true
T1_PLAN_SCHEDULE_TIME=15:45
T1_PLAN_STRATEGIES=短线,长线,多因子稳健型,激进突破型
T1_PLAN_SECTORS=全部,苹果概念,特斯拉概念,电力,算力租赁
T1_PLAN_NUM_STOCKS=5
T1_PLAN_PREHEAT_KLINE=true
T1_PLAN_PREHEAT_EXTENDED_INFO=true
T1_PLAN_PREHEAT_EXTENDED_INFO_MAX_SYMBOLS=5
T1_PLAN_PREHEAT_EXTENDED_INFO_TIMEOUT_SECONDS=20
T1_PLAN_PREHEAT_EXTENDED_INFO_DEEP=false
T1_PLAN_STRATEGY_TIMEOUT_SECONDS=300

# ===== 智能推荐 Alpha 评分（可选）=====
# 默认只给推荐股增加 Alpha 评分、理由和扣分项，不改变原策略排序。
# 如果把 RECOMMEND_RANKER_SORT 改成 true，才会按 Alpha 分重排。
RECOMMEND_RANKER_ENABLED=true
RECOMMEND_RANKER_SORT=false
