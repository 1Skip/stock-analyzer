# 本机私密配置模板
# 使用方法：复制本文件为 .env，然后把下面的占位值改成你自己的配置。
# .env 已在 .gitignore 中，不会提交到 GitHub。

# ===== LLM 多空辩论（DeepSeek 官方 API 示例）=====
AI_DEBATE_ENABLED=true
AI_API_KEY=sk-替换成你的DeepSeekKey
AI_BASE_URL=https://api.deepseek.com
AI_MODEL=deepseek/deepseek-v4-pro
AI_DEBATE_MAX_SYMBOLS=3

# ===== 本机飞书推送（可选）=====
# 如果只在 GitHub Actions 云端推送，本机可以不填飞书。
NOTIFY_CHANNELS=feishu
FEISHU_WEBHOOK_URL=替换成你的飞书机器人Webhook

# ===== 日报推荐池（可选）=====
DAILY_REPORT_INCLUDE_RECOMMENDATIONS=true
